# Project specific (optional)
# Если вы используете Alembic, можно добавить миграции, но их обычно коммитят:
# alembic/versions/*.py (но не __pycache__)
# Однако если вы хотите исключить все сгенерированные миграции, раскомментируйте:
# alembic/versions/*.py